---
// Client-side password gate. This keeps casual visitors and search engines out;
// it is NOT real security. A determined visitor can read the page source or
// fetch image URLs directly. For genuine protection the site would need
// server-side auth (a Cloud Function in front of Hosting) and private storage.
//
// The password is stored as a SHA-256 hash so the plaintext isn't sitting in the
// bundle, but the gate itself is still bypassable — treat it as a soft lock.
const PASSWORD_HASH =
  '1d1a34c2ce858a055a94b6d0823a069f4123feda5e6aaeb21c2f9ed75f3491b7';
---

<div class="gate" id="password-gate" hidden>
  <form class="gate-form" id="gate-form">
    <p class="gate-title">Zouf</p>
    <label class="gate-label" for="gate-input">This gallery is private</label>
    <div class="gate-row">
      <input
        class="gate-input"
        id="gate-input"
        type="password"
        autocomplete="current-password"
        aria-label="Password"
        autofocus
      />
      <button class="gate-submit" type="submit">Enter</button>
    </div>
    <p class="gate-error" id="gate-error" hidden>Incorrect password</p>
  </form>
</div>

<script is:inline define:vars={{ PASSWORD_HASH }}>
  (() => {
    const KEY = 'zouf-gallery-unlocked';
    const root = document.documentElement;
    const gate = document.getElementById('password-gate');
    const form = document.getElementById('gate-form');
    const input = document.getElementById('gate-input');
    const error = document.getElementById('gate-error');

    function unlock() {
      root.classList.remove('locked');
      gate.hidden = true;
    }

    // Already unlocked this session? Reveal immediately.
    if (sessionStorage.getItem(KEY) === '1') {
      unlock();
      return;
    }

    // Not unlocked: show the gate (content is hidden by the `locked` class,
    // applied inline in <head> so it never flashes).
    gate.hidden = false;

    async function sha256Hex(text) {
      const bytes = new TextEncoder().encode(text);
      const digest = await crypto.subtle.digest('SHA-256', bytes);
      return [...new Uint8Array(digest)]
        .map((b) => b.toString(16).padStart(2, '0'))
        .join('');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const hash = await sha256Hex(input.value);
      if (hash === PASSWORD_HASH) {
        sessionStorage.setItem(KEY, '1');
        unlock();
      } else {
        error.hidden = false;
        input.value = '';
        input.focus();
      }
    });
  })();
</script>

<style>
  .gate {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .gate-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: 20rem;
    text-align: center;
  }

  .gate-title {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 0;
  }

  .gate-label {
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin: 0;
  }

  .gate-row {
    display: flex;
    gap: 0.5rem;
    width: 100%;
  }

  .gate-input {
    flex: 1;
    min-width: 0;
    padding: 0.7rem 0.85rem;
    font-size: 1rem;
    color: var(--text);
    background: var(--bg-raised);
    border: 1px solid var(--rule);
    border-radius: 3px;
    outline: none;
    transition: border-color 0.15s;
  }

  .gate-input:focus {
    border-color: var(--text);
  }

  .gate-submit {
    padding: 0.7rem 1.1rem;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    color: var(--bg);
    background: var(--text);
    border: 1px solid var(--text);
    border-radius: 3px;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .gate-submit:hover {
    opacity: 0.85;
  }

  .gate-submit:focus-visible {
    outline: 2px solid var(--text);
    outline-offset: 2px;
  }

  .gate-error {
    font-size: 0.78rem;
    color: #a2432b;
    margin: 0;
  }
</style>
