---
import '../styles/theme.css';
import manifest from '../../photos.json';
import PasswordGate from '../components/PasswordGate.astro';

const { title, description } = Astro.props;
const path = Astro.url.pathname;
const albums = manifest.albums.map((a) => ({ slug: a.slug, title: a.title }));
---

<!doctype html>
<html lang="en" class="locked">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <!-- Hide content until the gate unlocks. Inline so it applies before paint,
         with no flash of the gallery. Kept minimal so a JS-less visitor who
         removes the class still can't see anything the gate would hide. -->
    <style is:inline>
      html.locked body > *:not(#password-gate) {
        display: none !important;
      }
    </style>
  </head>
  <body>
    <PasswordGate />
    <header class="wrap site-header">
      <a href="/" class="wordmark">Zouf</a>
      <nav>
        {
          albums.map((album) => (
            <a
              href={`/albums/${album.slug}`}
              aria-current={path.startsWith(`/albums/${album.slug}`) ? 'page' : undefined}
            >
              {album.title}
            </a>
          ))
        }
        <a href="/about" aria-current={path.startsWith('/about') ? 'page' : undefined}>About</a>
      </nav>
    </header>

    <main class="wrap"><slot /></main>

    <footer class="wrap site-footer">
      <span>&copy; {new Date().getFullYear()} Matt Zouf</span>
      <a href="mailto:mattzouf@gmail.com">mattzouf@gmail.com</a>
    </footer>

    <style>
      .site-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1.5rem 2rem;
        padding-top: 2.5rem;
        padding-bottom: 2.75rem;
        flex-wrap: wrap;
      }

      .wordmark {
        font-size: 1.05rem;
        font-weight: 600;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        text-decoration: none;
      }

      nav {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
      }

      nav a {
        font-size: 0.78rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-muted);
        text-decoration: none;
        padding-bottom: 2px;
        border-bottom: 1px solid transparent;
        transition: color 0.15s, border-color 0.15s;
      }

      nav a:hover,
      nav a[aria-current='page'] {
        color: var(--text);
        border-bottom-color: var(--text);
      }

      .site-footer {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 5rem;
        padding-top: 2rem;
        padding-bottom: 3rem;
        border-top: 1px solid var(--rule);
        font-size: 0.76rem;
        color: var(--text-muted);
      }

      .site-footer a {
        color: inherit;
        text-decoration: none;
      }

      .site-footer a:hover {
        color: var(--text);
      }
    </style>
  </body>
</html>
